      </div>
    </div>
  </section>

  <div class="container">
    <div class="footer-cta">
      <h2>ابدأ الآن مع SwiftFlow</h2>
      <p>اضغط على زر الاشتراك للانتقال مباشرة إلى البوت، أو استخدم زر خدمة العملاء للتواصل مع الدعم.</p>
      <div class="footer-actions">
        <a class="btn btn-gold" href="https://t.me/subomarbot" target="_blank">الاشتراك عبر البوت</a>
        <a class="btn btn-dark" href="https://t.me/SwiftFlow_Support" target="_blank">خدمة العملاء</a>
      </div>
      <div class="muted-note">الأسعار في الشريط تتحدث تلقائيًا، والنتائج تُقرأ من report.json.</div>
    </div>
  </div>

  <script>
    const API_KEY = "d6mb1qhr01qi0ajljak0d6mb1qhr01qi0ajljakg";

    const tickerSymbols = [
      { symbol: "NVDA", label: "NVIDIA" },
      { symbol: "AAPL", label: "Apple" },
      { symbol: "MSFT", label: "Microsoft" },
      { symbol: "AMZN", label: "Amazon" },
      { symbol: "GOOGL", label: "Alphabet" },
      { symbol: "META", label: "Meta" },
      { symbol: "TSLA", label: "Tesla" },
      { symbol: "AVGO", label: "Broadcom" },
      { symbol: "BRK.B", label: "Berkshire" },
      { symbol: "LLY", label: "Eli Lilly" },
      { symbol: "QQQ", label: "NASDAQ" },
      { symbol: "DIA", label: "Dow Jones" },
      { symbol: "VXX", label: "VIX" },
      { symbol: "UUP", label: "DXY" },
      { symbol: "IEF", label: "US10Y" }
    ];

    function classForChange(change){
      if (change > 0) return "up";
      if (change < 0) return "down";
      return "flat";
    }

    function arrowForChange(change){
      if (change > 0) return "▲";
      if (change < 0) return "▼";
      return "•";
    }

    async function getQuote(symbol){
      const res = await fetch(`https://finnhub.io/api/v1/quote?symbol=${encodeURIComponent(symbol)}&token=${API_KEY}`);
      return await res.json();
    }

    function renderTickerItems(items){
      return items.map(item => `
        <div class="ticker-item">
          <span class="ticker-symbol">${item.label}</span>
          <span>${item.price}</span>
          <span class="${item.changeClass}">${item.arrow} ${item.change}</span>
        </div>
      `).join("");
    }

    async function loadTicker(){
      const trackA = document.getElementById("tickerTrackA");
      const trackB = document.getElementById("tickerTrackB");

      const results = [];

      for (const item of tickerSymbols){
        try{
          const q = await getQuote(item.symbol);
          const price = (typeof q.c === "number" && !Number.isNaN(q.c) && q.c !== 0) ? q.c.toFixed(2) : "--";
          const change = (typeof q.d === "number" && !Number.isNaN(q.d)) ? q.d.toFixed(2) : "--";
          const cls = (typeof q.d === "number") ? classForChange(q.d) : "flat";
          const arrow = (typeof q.d === "number") ? arrowForChange(q.d) : "•";

          results.push({
            label: item.label,
            price,
            change,
            changeClass: cls,
            arrow
          });
        }catch(e){
          results.push({
            label: item.label,
            price: "--",
            change: "--",
            changeClass: "flat",
            arrow: "•"
          });
        }
      }

      const html = renderTickerItems(results);
      trackA.innerHTML = html;
      trackB.innerHTML = html;
    }

    fetch("/report.json", { cache: "no-store" })
    .then(r => r.json())
    .then(data => {
      document.querySelector("#dailyAmount").textContent = "+$" + data.daily.amount;
      document.querySelector("#dailyDate").textContent = data.daily.date;

      document.querySelector("#weeklyAmount").textContent = "+$" + data.weekly.amount;
      document.querySelector("#weeklyFrom").textContent = data.weekly.from;
      document.querySelector("#weeklyTo").textContent = data.weekly.to;

      document.querySelector("#monthlyAmount").textContent = "+$" + data.monthly.amount;
      document.querySelector("#monthlyFrom").textContent = data.monthly.from;
      document.querySelector("#monthlyTo").textContent = data.monthly.to;
    })
    .catch(() => {});

    loadTicker();
    setInterval(loadTicker, 15000);
  </script>
</body>
</html>
