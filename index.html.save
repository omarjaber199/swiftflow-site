      width:92px;
      height:4px;
      border-radius:999px;
      background:linear-gradient(90deg,var(--gold),var(--gold2));
      margin:0 auto 14px;
    }

    .section-head h2{
      margin:0;
      font-size:34px;
      letter-spacing:-.6px;
    }

    .section-head p{
      margin:10px auto 0;
      max-width:800px;
      color:var(--muted);
      font-size:17px;
      line-height:1.8;
    }

    .results-grid{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:18px;
    }

    .performance-card,
    .card{
      background:linear-gradient(180deg, rgba(255,255,255,.035), rgba(255,255,255,.02));
      border:1px solid var(--line);
      border-radius:24px;
      padding:22px;
      box-shadow:var(--shadow);
    }

    .tv-badge{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      padding:10px 14px;
      border-radius:999px;
      background:rgba(59,130,246,.12);
      border:1px solid rgba(59,130,246,.22);
      color:#9cc2ff;
      font-size:13px;
      font-weight:800;
      margin-bottom:14px;
    }

    .performance-card{
      text-align:center;
      background:#0b1320;
    }

    .performance-card .small{
      color:var(--muted);
      font-size:14px;
      margin-bottom:10px;
    }

    .performance-card .big{
      font-size:30px;
      font-weight:900;
      margin-bottom:8px;
    }

    .performance-date{
      font-size:13px;
      color:#94a3b8;
      line-height:1.7;
    }

    .features-grid,
    .steps-grid,
    .reviews-grid,
    .news-grid{
      display:grid;
      gap:18px;
    }

    .features-grid{grid-template-columns:repeat(4,1fr)}
    .steps-grid{grid-template-columns:repeat(3,1fr)}
    .reviews-grid{grid-template-columns:repeat(3,1fr)}
    .news-grid{grid-template-columns:repeat(3,1fr)}

    .feature-icon{
      width:48px;
      height:48px;
      border-radius:14px;
      display:grid;
      place-items:center;
      background:rgba(212,165,73,.1);
      color:var(--gold2);
      font-size:24px;
      margin:0 auto 14px;
    }

    .card{
      text-align:center;
    }

    .card h3{
      margin:0 0 10px;
      font-size:22px;
    }

    .card p{
      margin:0;
      color:var(--muted);
      line-height:1.85;
      font-size:16px;
    }

    .step-num{
      width:46px;
      height:46px;
      border-radius:50%;
      display:grid;
      place-items:center;
      background:linear-gradient(135deg,var(--gold),var(--gold2));
      color:#111;
      font-weight:900;
      margin:0 auto 14px;
    }

    .review-top{
      display:flex;
      align-items:center;
      justify-content:center;
      gap:12px;
      margin-bottom:14px;
    }

    .avatar{
      width:50px;
      height:50px;
      border-radius:50%;
      background:linear-gradient(135deg,var(--gold),#8f6a2e);
      display:grid;
      place-items:center;
      color:#111;
      font-weight:900;
    }

    .review-name{
      font-size:17px;
      font-weight:800;
    }

    .review-tag{
      color:var(--muted);
      font-size:13px;
      margin-top:4px;
    }

    .stars{
      color:var(--gold2);
      font-size:18px;
      letter-spacing:2px;
      margin-top:14px;
    }

    .review-cta{
      text-align:center;
      margin-top:18px;
    }

    .news-badge{
      display:inline-block;
      padding:8px 12px;
      border-radius:999px;
      background:rgba(255,255,255,.04);
      border:1px solid var(--line);
      color:var(--gold2);
      font-size:12px;
      font-weight:800;
      margin-bottom:14px;
    }

    .news-title{
      font-size:22px;
      font-weight:900;
      margin-bottom:14px;
    }

    .econ{
      display:grid;
      gap:10px;
      margin-top:14px;
    }

    .econ-row{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:12px 14px;
      border-radius:14px;
      background:#0b1320;
      border:1px solid var(--line);
      font-size:15px;
    }

    .econ-row span:first-child{color:var(--muted)}
    .econ-row span:last-child{font-weight:900}

    .footer-cta{
      margin:42px 0 70px;
      padding:28px;
      border-radius:28px;
      border:1px solid rgba(212,165,73,.14);
      background:
        radial-gradient(circle at left, rgba(212,165,73,.08), transparent 28%),
        linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.02));
      box-shadow:var(--shadow);
      text-align:center;
    }

    .footer-cta h2{
      margin:0 0 10px;
      font-size:34px;
    }

    .footer-cta p{
      margin:0 0 20px;
      color:var(--muted);
      font-size:17px;
      line-height:1.85;
    }

    .footer-actions{
      display:flex;
      justify-content:center;
      gap:12px;
      flex-wrap:wrap;
    }

    .muted-note{
      margin-top:16px;
      color:#95a0b1;
      font-size:13px;
    }

    @media (max-width:1100px){
      .hero-grid{grid-template-columns:1fr}
      .hero-stats{grid-template-columns:repeat(2,1fr)}
      .features-grid{grid-template-columns:repeat(2,1fr)}
      .reviews-grid,.news-grid,.results-grid{grid-template-columns:1fr}
    }

    @media (max-width:760px){
      .nav{flex-direction:column;align-items:stretch}
      .nav-links{justify-content:center}
      .hero h1{font-size:42px}
      .hero p{font-size:17px}
      .hero-stats,
      .features-grid,
      .steps-grid{grid-template-columns:1fr}
      .section-head h2{font-size:30px}
    }
  </style>
</head>
<body>

